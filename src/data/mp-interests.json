  "metadata": {
    "title": "MPs' Financial Interests, Gifts & Expenses",
    "description": "Data from the Register of Members' Financial Interests (Parliament) and the Independent Parliamentary Standards Authority (IPSA). The Register tracks declared outside earnings, gifts, hospitality, shareholdings, and other interests. IPSA publishes all parliamentary expenses claims.",
    "primarySources": [
      {
        "name": "Register of Members' Financial Interests",
        "url": "https://www.parliament.uk/mps-lords-and-offices/standards-and-financial-interests/parliamentary-commissioner-for-standards/registers-of-interests/register-of-members-financial-interests/",
        "notes": "Updated every 2 weeks. 10 categories of declarable interest. Thresholds: external employment >£100 per payment, gifts/hospitality >£300, donations >£1,500. Published under Open Parliament Licence."
      },
      {
        "name": "Independent Parliamentary Standards Authority (IPSA)",
        "url": "https://www.theipsa.org.uk/mp-staffing-business-costs/annual-publications",
        "notes": "Publishes all MP business costs and expenses every 2 months. Individual claims searchable. Annual publications since 2010-11."
      }
    ],
    "sourceConfidence": "high",
    "lastUpdated": "2026-05-12",
    "registerEditionReviewed": "as at 27 Apr 2026",
    "dataRange": "2019–2025 (interests), 2019–2024 (expenses)",
    "methodologyNote": "Interests data compiled from Parliamentary Commissioner for Standards publications and verified journalism citing the official register. Expenses data from IPSA annual publications. Historical top-earner data (2019-2024) is from the cumulative register. Current Parliament data covers July 2024 onward.",
