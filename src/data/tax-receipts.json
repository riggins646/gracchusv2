      },
      {
        "name": "OBR Public Finances Databank",
        "url": "https://obr.uk/data/",
        "notes": "OBR uses ONS public sector current receipts which is broader than HMRC-administered taxes. ONS total includes council tax, business rates, and other non-HMRC receipts. HMRC series is a subset."
      }
    ],
    "methodologyNotes": "HMRC receipts cover taxes and NICs administered by HMRC only. This excludes council tax, business rates, vehicle excise duty (post-DVLA transfer), and other non-HMRC revenues. ONS 'public sector current receipts' is a broader measure (~15-20% higher) that includes all government income. We use HMRC as the primary series for tax breakdown granularity. All figures in billions of pounds, financial year basis (e.g. 2024-25 = April 2024 to March 2025). The \"other\" category is calculated as a residual (total minus individually named taxes) and includes: insurance premium tax, air passenger duty, customs duties, climate change levy, aggregates levy, landfill tax, soft drinks industry levy, betting/gaming duties, and other minor taxes. In recent years this residual has grown as some individual categories may use slightly different classification boundaries between HMRC publications.",
    "unit": "billions_gbp",
    "period": "financial_year",
    "lastUpdated": "2026-03",
    "sourceConfidence": "high"
  },
