# deploy/.env.example — copy to deploy/.env and fill in.
# `bin/setup.sh env` creates deploy/.env and auto-fills the path lines.
# NEVER commit the real deploy/.env (it is gitignored).

# ── Required ──────────────────────────────────────────────────────────
# Your Anthropic API key. The three judgment jobs bill per token via the API.
ANTHROPIC_API_KEY=sk-ant-...

# ── Auto-filled by `bin/setup.sh env` (absolute paths => cron/systemd safe) ──
# CLAUDE_BIN=/home/YOU/.npm-global/bin/claude
# NODE_BIN=/usr/bin/node
# GRACCHUS_REPO_DIR=/opt/gracchus

# ── Optional overrides (defaults live in bin/lib.sh) ──────────────────
# CLAUDE_MODEL=sonnet
# CLAUDE_MAX_TURNS=40          # cost/turn cap for judgment jobs; set empty to remove
# GIT_BRANCH=main
# GIT_AUTHOR_NAME=Gracchus Bot
# GIT_AUTHOR_EMAIL=bot@gracchus.ai
